{
  "name": "enterprise-sandbox",
  "random_seed": 42,
  "safety": {
    "workspace_prefix": "DZ-SBX",
    "project_prefix": "DZ-SBX",
    "teardown_requires_prefix_match": true
  },
  "platforms": {
    "powerbi": {
      "enabled": true,
      "tenant_id_env": "POWERBI_TENANT_ID",
      "client_id_env": "POWERBI_CLIENT_ID",
      "client_secret_env": "POWERBI_CLIENT_SECRET",
      "workspace_prefix": "DZ-SBX"
    },
    "tableau": {
      "enabled": false,
      "host_name_env": "TABLEAU_HOST_NAME",
      "token_name_env": "TABLEAU_TOKEN_NAME",
      "token_secret_env": "TABLEAU_TOKEN_SECRET",
      "site_name": "datalogzbiopsuseast",
      "api_version": "3.25",
      "project_prefix": "DZ-SBX"
    }
  },
  "sources": [
    {
      "name": "snowflake_finance",
      "kind": "warehouse",
      "owner": "finance-data",
      "connection_hint": "snowflake://finance"
    },
    {
      "name": "postgres_ops",
      "kind": "database",
      "owner": "ops-analytics",
      "connection_hint": "postgres://ops"
    },
    {
      "name": "s3_marketing_files",
      "kind": "file",
      "owner": "marketing-analytics",
      "connection_hint": "s3://marketing-sandbox"
    },
    {
      "name": "crm_service",
      "kind": "saas",
      "owner": "revops",
      "connection_hint": "salesforce://sandbox"
    }
  ],
  "template_families": [
    {
      "name": "finance-powerbi-pack",
      "platform": "powerbi",
      "asset_kind": "report",
      "path": "../templates/powerbi/finance-pack.pbix",
      "source_ref": "snowflake_finance",
      "owners": [
        "finops@example.com",
        "finance-director@example.com"
      ],
      "mutation_tags": [
        "managed",
        "refresh-heavy"
      ]
    },
    {
      "name": "operations-powerbi-pack",
      "platform": "powerbi",
      "asset_kind": "report",
      "path": "../templates/powerbi/operations-pack.pbix",
      "source_ref": "postgres_ops",
      "owners": [
        "ops-analytics@example.com"
      ],
      "mutation_tags": [
        "shadow",
        "long-refresh"
      ]
    },
    {
      "name": "marketing-tableau-pack",
      "platform": "tableau",
      "asset_kind": "workbook",
      "path": "../templates/tableau/marketing-pack.twbx",
      "source_ref": "s3_marketing_files",
      "owners": [
        "growth@example.com"
      ],
      "mutation_tags": [
        "extract",
        "uncertified"
      ]
    },
    {
      "name": "executive-tableau-pack",
      "platform": "tableau",
      "asset_kind": "workbook",
      "path": "../templates/tableau/executive-pack.twbx",
      "source_ref": "crm_service",
      "owners": [
        "ceo-ops@example.com"
      ],
      "mutation_tags": [
        "executive",
        "high-visibility"
      ]
    }
  ],
  "domains": [
    {
      "name": "Finance",
      "teams": [
        "Close",
        "FP&A",
        "Shared Services"
      ],
      "powerbi_workspaces_per_team": 2,
      "tableau_projects_per_team": 2,
      "asset_multiplier": 9,
      "template_families": [
        "finance-powerbi-pack",
        "executive-tableau-pack"
      ],
      "executive_ratio": 0.2,
      "shadow_ratio": 0.15,
      "stale_ratio": 0.25,
      "duplicate_ratio": 0.35
    },
    {
      "name": "Operations",
      "teams": [
        "Network",
        "Support",
        "Field Ops"
      ],
      "powerbi_workspaces_per_team": 3,
      "tableau_projects_per_team": 1,
      "asset_multiplier": 12,
      "template_families": [
        "operations-powerbi-pack",
        "marketing-tableau-pack"
      ],
      "executive_ratio": 0.05,
      "shadow_ratio": 0.35,
      "stale_ratio": 0.3,
      "duplicate_ratio": 0.4
    }
  ],
  "scenarios": {
    "refresh_failure_rate": 0.12,
    "ownership_drift_rate": 0.18,
    "export_spike_rate": 0.08,
    "dormant_ratio": 0.3,
    "rename_noise_rate": 0.15
  }
}